# ==================== AWS CREDENTIALS ====================
# Get these from AWS IAM console or AWS CLI configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# ==================== AWS BEDROCK ====================
# Claude 3 Haiku model endpoint (no additional credentials needed if using IAM role)
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_REGION=us-east-1

# ==================== AWS DYNAMODB ====================
# Table names for storing queries, users, and saved schemes
DYNAMODB_QUERIES_TABLE=sahaay-queries
DYNAMODB_USERS_TABLE=sahaay-users
DYNAMODB_SAVED_SCHEMES_TABLE=sahaay-saved-schemes
DYNAMODB_REGION=us-east-1

# ==================== AWS S3 ====================
# Bucket for storing government scheme documents
AWS_S3_BUCKET=sahaay-documents
AWS_S3_REGION=us-east-1

# ==================== DATABASE ====================
# MongoDB for auth and basic user data
# NEVER commit actual credentials - set in .env locally
MONGO_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/sahaay?retryWrites=true&w=majority
DB_NAME=sahaay

# ==================== SERVER ====================
NODE_ENV=development
PORT=5000

# ==================== JWT ====================
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# ==================== LOGGING ====================
LOG_LEVEL=info
LOG_FILE=./logs/server.log

# ==================== DEPLOYMENT ====================
# Use these for AWS Lambda deployment
LAMBDA_FUNCTION_NAME=sahaay-civic-ai
LAMBDA_HANDLER=lambda.handler
